<%
  const data = locals || {};
  const safeRecipientName = data.recipientName || "there";
  const otp = data.otp;
  const safeLogoUrl = data.logoUrl || "";
  const safePreheaderText =
    data.preheaderText ||
    `Your OTP for liminal is ${otp}. It expires in 5 minutes.`;
%>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OTP Verification Code - Liminal</title>
    <style>
      /* Base email reset and global layout */
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        background-color: #f3f7f6;
        font-family: Arial, Helvetica, sans-serif;
        color: #16302b;
      }

      .preheader {
        display: none;
        overflow: hidden;
        line-height: 1px;
        opacity: 0;
        max-height: 0;
        max-width: 0;
      }

      .page {
        background-color: #f3f7f6;
        margin: 0;
        padding: 24px 12px;
      }

      .content {
        max-width: 620px;
        margin: 0 auto;
      }

      /* Brand header */
      .logo-wrap {
        padding-bottom: 16px;
        text-align: center;
      }

      .logo-image {
        max-width: 140px;
        height: auto;
        border: 0;
      }

      .brand-pill,
      .verification-badge {
        display: inline-block;
        background-color: #e6fffa;
        color: #0f766e;
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .brand-pill {
        padding: 10px 18px;
        font-size: 13px;
      }

      /* Main message card */
      .card {
        background-color: #ffffff;
        border-radius: 24px;
        padding: 40px 32px;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
      }

      .badge-wrap {
        padding-bottom: 24px;
      }

      .verification-badge {
        padding: 7px 14px;
        font-size: 12px;
      }

      .title {
        margin: 0;
        font-size: 28px;
        line-height: 1.3;
        font-weight: 700;
        color: #102a43;
        padding-bottom: 16px;
        text-align: center;
      }

      .intro {
        margin: 0;
        font-size: 16px;
        line-height: 1.8;
        color: #486581;
        padding-bottom: 24px;
      }

      .highlight-text {
        color: #102a43;
      }

      /* OTP highlight block */
      .otp-wrapper {
        padding-bottom: 28px;
      }

      .otp-box {
        background: linear-gradient(135deg, #f8fffd 0%, #eefbf8 100%);
        border: 1px solid #d9efe9;
        border-radius: 20px;
        text-align: center;
      }

      .otp-label {
        margin: 0;
        padding: 28px 16px 12px;
        font-size: 13px;
        color: #5c6f7b;
      }

      .otp-code {
        margin: 0;
        padding: 0 16px 28px;
        font-size: 34px;
        line-height: 1;
        font-weight: 700;
        letter-spacing: 10px;
        color: #0f766e;
      }

      .body-copy {
        margin: 0;
        font-size: 15px;
        line-height: 1.8;
        color: #52606d;
      }

      .body-copy-tight {
        padding-bottom: 12px;
      }

      .body-copy-loose {
        padding-bottom: 28px;
      }

      .support-link {
        color: #0f766e;
        text-decoration: none;
        font-weight: 600;
      }

      /* Footer copy inside the card */
      .footer-note {
        margin: 0;
        border-top: 1px solid #e6ecef;
        padding-top: 24px;
        font-size: 13px;
        line-height: 1.7;
        color: #7b8794;
        text-align: center;
      }

      .copyright {
        text-align: center;
        padding: 18px 16px 8px;
        font-size: 12px;
        line-height: 1.8;
        color: #7b8794;
        margin: 0;
      }

      /* Mobile spacing and type adjustments */
      @media (max-width: 640px) {
        .page {
          padding: 16px 10px;
        }

        .card {
          padding: 32px 20px;
          border-radius: 20px;
        }

        .title {
          font-size: 24px;
        }

        .otp-code {
          font-size: 28px;
          letter-spacing: 8px;
        }
      }
    </style>
  </head>
  <body>
    <div class="preheader">
      <%= safePreheaderText %>
    </div>

    <div class="page">
      <div class="content">
        <!-- Logo / brand area -->
        <div class="logo-wrap">
          <% if (safeLogoUrl) { %>
          <img
            class="logo-image"
            src="<%= safeLogoUrl %>"
            alt="liminal logo"
          />
          <% } else { %>
          <div class="brand-pill">
            Liminal
          </div>
          <% } %>
        </div>

        <!-- OTP message card -->
        <div class="card">
          <!-- Verification badge -->
          <div class="badge-wrap">
            <div class="verification-badge">
              Secure Verification
            </div>
          </div>

          <!-- Greeting and message -->
          <h1 class="title">Your One-Time Password</h1>

          <p class="intro">
            Hey <%= safeRecipientName %>!,<br />
            Use the OTP below to complete your verification.
            For your security, this code is valid for
            <strong class="highlight-text">5 minutes.</strong>.
          </p>

          <!-- OTP code block -->
          <div class="otp-wrapper">
            <div class="otp-box">
              <p class="otp-label">Verification Code:</p>
              <p class="otp-code"><%= otp %></p>
            </div>
          </div>

          <!-- Security and support notes -->
          <p class="body-copy body-copy-tight">
            If you did not request this code, you can safely ignore this
            email. Please do not share this OTP with anyone.
          </p>

          <p class="body-copy body-copy-loose">
            Need help? Contact us at:
            <a
              href="mailto:support@liminalbd.com"
              class="support-link"
              >support@liminalbd.com</a
            >.
          </p>

          <!-- Automated email disclaimer -->
          <p class="footer-note">
            This is an automated message from liminal.
            Please do not reply directly to this email.
          </p>
        </div>

        <!-- Copyright footer -->
        <p class="copyright">
          © <%= new Date().getFullYear() %> Liminal. All rights reserved.
        </p>
      </div>
    </div>
  </body>
</html>
