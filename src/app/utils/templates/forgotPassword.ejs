<%
  const data = locals || {};
  const recipientName = data.recipientName || "there";
  const resetUrl = data.resetUrl || "";
%>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Your Password - Liminal</title>
    <style>
      /* Base email reset and global layout */
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        background-color: #f3f7f6;
        font-family: Arial, Helvetica, sans-serif;
        color: #16302b;
      }

      a {
        color: inherit;
      }

      a[x-apple-data-detectors] {
        color: inherit !important;
        text-decoration: none !important;
      }

      .preheader {
        display: none;
        overflow: hidden;
        line-height: 1px;
        opacity: 0;
        max-height: 0;
        max-width: 0;
      }

      .page {
        background-color: #f3f7f6;
        margin: 0;
        padding: 24px 12px;
      }

      .content {
        max-width: 620px;
        margin: 0 auto;
      }

      /* Brand header */
      .logo-wrap {
        padding-bottom: 16px;
        text-align: center;
      }

      .logo-image {
        max-width: 140px;
        height: auto;
        border: 0;
      }

      .brand-pill,
      .security-badge {
        display: inline-block;
        background-color: #e6fffa;
        color: #0f766e;
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .brand-pill {
        padding: 10px 18px;
        font-size: 13px;
      }

      /* Main message card */
      .card {
        background-color: #ffffff;
        border-radius: 24px;
        padding: 40px 32px;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08);
      }

      .badge-wrap {
        padding-bottom: 24px;
      }

      .security-badge {
        padding: 7px 14px;
        font-size: 12px;
      }

      .title {
        margin: 0;
        font-size: 28px;
        line-height: 1.3;
        font-weight: 700;
        color: #102a43;
        padding-bottom: 16px;
        text-align: center;
      }

      .intro,
      .body-copy {
        margin: 0;
        font-size: 16px;
        line-height: 1.8;
        color: #486581;
      }

      .intro {
        padding-bottom: 16px;
      }

      .body-copy {
        font-size: 15px;
        color: #52606d;
      }

      .body-copy-tight {
        padding-bottom: 12px;
      }

      .body-copy-loose {
        padding-bottom: 28px;
      }

      .highlight-text {
        color: #102a43;
      }

      /* Reset action block */
      .action-wrapper {
        padding: 12px 0 28px;
      }

      .action-box {
        background: linear-gradient(135deg, #f8fffd 0%, #eefbf8 100%);
        border: 1px solid #d9efe9;
        border-radius: 20px;
        padding: 28px 24px;
        text-align: center;
      }

      .action-label {
        margin: 0;
        padding-bottom: 18px;
        font-size: 13px;
        color: #5c6f7b;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-weight: 700;
      }

      .reset-button {
        display: inline-block;
        padding: 14px 26px;
        border-radius: 999px;
        background-color: #0f766e;
        color: #ffffff !important;
        text-decoration: none !important;
        font-size: 15px;
        font-weight: 700;
      }

      .reset-button,
      .reset-button:link,
      .reset-button:visited,
      .reset-button span,
      .reset-button span:link,
      .reset-button span:visited {
        color: #ffffff !important;
        text-decoration: none !important;
      }

      .link-note {
        margin: 0;
        padding-top: 18px;
        font-size: 13px;
        line-height: 1.7;
        color: #5c6f7b;
      }

      .fallback-link {
        display: inline-block;
        margin-top: 10px;
        color: #0f766e;
        text-decoration: none;
        word-break: break-all;
        font-weight: 600;
      }

      .support-link {
        color: #0f766e !important;
        text-decoration: none !important;
        font-weight: 600 !important;
      }

      .support-link,
      .support-link:link,
      .support-link:visited,
      .support-link span,
      .support-link span:link,
      .support-link span:visited {
        color: #0f766e !important;
        text-decoration: none !important;
        font-weight: 600 !important;
      }

      u + .body .reset-button,
      u + .body .reset-button span,
      #MessageViewBody .reset-button,
      #MessageViewBody .reset-button span {
        color: #ffffff !important;
        text-decoration: none !important;
      }

      u + .body .support-link,
      u + .body .support-link span,
      #MessageViewBody .support-link,
      #MessageViewBody .support-link span {
        color: #0f766e !important;
        text-decoration: none !important;
        font-weight: 600 !important;
      }

      /* Footer copy inside the card */
      .footer-note {
        margin: 0;
        border-top: 1px solid #e6ecef;
        padding-top: 24px;
        font-size: 13px;
        line-height: 1.7;
        color: #7b8794;
        text-align: center;
      }

      .copyright {
        text-align: center;
        padding: 18px 16px 8px;
        font-size: 12px;
        line-height: 1.8;
        color: #7b8794;
        margin: 0;
      }

      /* Mobile spacing and type adjustments */
      @media (max-width: 640px) {
        .page {
          padding: 16px 10px;
        }

        .card {
          padding: 32px 20px;
          border-radius: 20px;
        }

        .title {
          font-size: 24px;
        }

        .action-box {
          padding: 24px 18px;
        }

        .reset-button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body class="body">
    <div class="page">
      <div class="content">
        <!-- Password reset message card -->
        <div class="card" style="margin: 40px auto;">
          <!-- Security badge -->
          <div class="badge-wrap">
            <div class="security-badge">
              Password Recovery
            </div>
          </div>

          <!-- Greeting and message -->
          <h1 class="title">Reset Your Password</h1>

          <p class="intro">
            Hey <%= recipientName %>!,<br />
            We received a request to reset your password for
            liminal. Use the secure button below to create a new password.
          </p>
          <!-- Reset action block -->
          <div class="action-wrapper">
            <div class="action-box">
              <p class="action-label">Secure Reset Link</p>
               <a
                class="reset-button"
                href="<%= resetUrl %>"
                style="
                  display: inline-block;
                  padding: 14px 26px;
                  border-radius: 999px;
                  background-color: #0f766e;
                  color: #ffffff !important;
                  text-decoration: none !important;
                  font-size: 15px;
                  font-weight: 700;
                "
              >
                <span style="color: #ffffff !important; text-decoration: none !important;">
                  Reset Password
                </span>
              </a>

              <p class="link-note">
                Click the button above to reset your password. <br>
                <strong class="highlight-text">Note:</strong> The link will expire in 10 minutes.
              </p>
            </div>
          </div>

          <!-- Security and support notes -->
          <p class="body-copy body-copy-tight">
            If you did not request a password reset, you can safely ignore this
            email. Your current password will remain unchanged.
          </p>

          <p class="body-copy body-copy-loose">
            Need help? Contact us at:
            <a
              href="mailto:support@liminalbd.com"
              class="support-link"
              style="color: #0f766e !important; text-decoration: none !important; font-weight: 600 !important;"
            >
              <span style="color: #0f766e !important; text-decoration: none !important; font-weight: 600 !important;">
                support@liminalbd.com
              </span>
            </a>.
          </p>

         <!-- Copyright footer -->
          <p class="footer-note">
            © <%= new Date().getFullYear() %> Liminal. All rights reserved.
          </p>         
        </p>
        </div>
      </div>
    </div>
  </body>
</html>
